# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=""

# Auth.js v5 — Google OAuth credentials
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# OpenAI API key for bias analysis (gpt-4o-mini)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
